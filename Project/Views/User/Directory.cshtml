@model IEnumerable<EmployeeApp.Models.Employee>

@{
    ViewData["Title"] = "Colleague Directory";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-people text-primary me-2"></i>Colleague Directory</h2>
</div>
<p class="text-muted mb-4">A privacy-safe view to find and identify your coworkers.</p>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <form asp-action="Directory" method="get" class="d-flex gap-2">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control border-start-0" placeholder="Search colleagues by name..." />
            </div>
            <button type="submit" class="btn btn-primary px-4 text-nowrap">Search</button>
            @if(!string.IsNullOrEmpty(ViewBag.SearchString)) {
                <a asp-action="Directory" class="btn btn-outline-secondary px-3 text-nowrap">Clear</a>
            }
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card h-100 shadow-sm border-0 text-center p-4">
                <div class="mb-3">
                    @if (item.Photo != null)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(item.Photo)" class="rounded-circle shadow-sm border" style="width: 80px; height: 80px; object-fit: cover;" alt="avatar"/>
                    }
                    else
                    {
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.Name ?? "U")&background=random&color=fff&size=80" class="rounded-circle shadow-sm border" style="width: 80px; height: 80px;" alt="avatar"/>
                    }
                </div>
                <h5 class="fw-bold text-dark mb-1">@item.Name</h5>
                <p class="text-muted small mb-0"><i class="bi bi-calendar-event me-1"></i>Joined: @item.JoiningDate.ToString("MMM yyyy")</p>
                <div class="mt-3">
                    <span class="badge bg-light text-primary border rounded-pill px-3 py-2 fw-normal">EMP-@item.Id.ToString("D5")</span>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="text-center py-5 text-muted bg-white rounded shadow-sm">
                <i class="bi bi-people display-4 d-block mb-3"></i>
                No colleagues found.
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
<div class="mt-4 d-flex justify-content-between align-items-center bg-white p-3 rounded shadow-sm">
    <div class="text-muted small fw-medium">
        Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages
    </div>
    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Directory" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewBag.SearchString">Previous</a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Directory" asp-route-page="@i" asp-route-searchString="@ViewBag.SearchString">@i</a>
                </li>
            }
            <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Directory" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewBag.SearchString">Next</a>
            </li>
        </ul>
    </nav>
</div>
}
