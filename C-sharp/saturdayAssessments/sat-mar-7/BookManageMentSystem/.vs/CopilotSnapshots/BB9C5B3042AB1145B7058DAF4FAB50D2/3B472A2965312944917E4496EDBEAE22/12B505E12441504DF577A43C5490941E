@model List<BookManageMentSystem.Models.Book>

@{
    ViewData["Title"] = "Books by Price";
    var maxPrice = ViewContext.RouteData.Values["price"]?.ToString() ?? "N/A";
}

<div class="container mt-4">
    <h1 class="mb-4">@ViewData["Title"]</h1>
    <p class="lead">Books with price up to: <strong>$@maxPrice</strong></p>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            <p>No books found with price up to $@maxPrice</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Book ID</th>
                        <th>Name</th>
                        <th>Author</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.BookId</td>
                            <td>@book.Name</td>
                            <td>@book.Author</td>
                            <td>$@book.Price.ToString("F2")</td>
                            <td>
                                <a asp-action="BookByName" asp-route-name="@book.Name" class="btn btn-sm btn-primary">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">Books Found: <strong>@Model.Count</strong></p>
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary">View All Books</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
    </div>
</div>
